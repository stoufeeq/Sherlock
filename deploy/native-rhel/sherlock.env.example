# /etc/sherlock/sherlock.env — read by /etc/systemd/system/sherlock.service
# Generated by deploy/native-rhel/install-sherlock.sh; copy this file there
# manually if you're running the install steps by hand.

SHERLOCK_LOG_LEVEL=INFO

# ---- Local GitLab (same VM, port 8080) -------------------------------------
# Use http://localhost:8080 internally so Sherlock and GitLab loopback fast.
# EXTERNAL_URL is what gets put in MR comments + sticky-issue links — must be
# resolvable from a browser on a developer laptop.
GITLAB_INTERNAL_URL=http://localhost:8080
GITLAB_EXTERNAL_URL=http://CHANGE_ME_TO_VM_HOSTNAME:8080
# Personal Access Token created via the GitLab UI (api + write_repository scopes)
GITLAB_TOKEN=CHANGE_ME_TO_PAT
GITLAB_GROUP=banking
# Multiple groups — overrides GITLAB_GROUP. Uncomment + edit when adding domains.
# GITLAB_GROUPS=banking,wealth,payments

# ---- Local Neo4j (same VM) -------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sherlock-dev

# ---- Local CMDB stub (same VM, port 8500) ----------------------------------
# Replace with the real corporate CMDB URL once an adapter is wired.
CMDB_URL=http://localhost:8500

# ---- Webhook secret + URL --------------------------------------------------
# Generate the secret with: openssl rand -hex 32
WEBHOOK_SECRET=CHANGE_ME_TO_RANDOM_HEX
SHERLOCK_WEBHOOK_URL=http://localhost:8001/webhooks/gitlab

# ---- Reconciler ------------------------------------------------------------
RECONCILE_ENABLED=true
RECONCILE_INTERVAL_SECONDS=300

# ---- LLM provider (autodoc) ------------------------------------------------
# mock | gemini | azure_openai
SHERLOCK_LLM_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-06-01

# ---- API gateway resolver --------------------------------------------------
# Path to the APIGEE-bundle-shaped routing table.
SHERLOCK_GATEWAY_CONFIG=/etc/sherlock/gateway-routes.yaml
