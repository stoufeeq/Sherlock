[Unit]
Description=Sherlock CMDB stub (POC only — replace with real CMDB adapter for pilot)
Documentation=https://github.com/stoufeeq/Sherlock
After=network-online.target

[Service]
Type=exec
WorkingDirectory=@SHERLOCK_HOME@/services/sherlock-cmdb-stub
ExecStart=@SHERLOCK_HOME@/cmdb-venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8500
Restart=on-failure
RestartSec=5
User=sherlock
Group=sherlock

[Install]
WantedBy=multi-user.target
