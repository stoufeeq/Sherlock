# GitLab
GITLAB_HOSTNAME=localhost
GITLAB_HTTP_PORT=8080
GITLAB_SSH_PORT=2222
# Set after first boot — see `make gitlab-root-password`
GITLAB_ROOT_PASSWORD=
# Personal Access Token — create one via the UI after GitLab boots
GITLAB_TOKEN=

# Postgres (shared by fixture apps; Sherlock will use a separate DB in Loop 2)
POSTGRES_USER=banking
POSTGRES_PASSWORD=banking
POSTGRES_DB=banking

# Redpanda (Kafka-compatible)
REDPANDA_BROKER=localhost:9092

# CMDB stub
CMDB_PORT=8500

# Neo4j (graph DB)
NEO4J_USER=neo4j
NEO4J_PASSWORD=sherlock-dev
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Sherlock service
SHERLOCK_PORT=8001
SHERLOCK_LOG_LEVEL=INFO
GITLAB_GROUP=banking
# Optional — comma-separated list of groups. When set, overrides GITLAB_GROUP.
# GITLAB_GROUPS=banking,wealth,payments
WEBHOOK_SECRET=sherlock-local-dev

# Reconciler
RECONCILE_ENABLED=true
RECONCILE_INTERVAL_SECONDS=300

# Sherlock LLM provider (Loop 6 — autodoc)
# Options: mock | gemini | azure_openai
SHERLOCK_LLM_PROVIDER=mock

# Gemini (local dev) — set provider to 'gemini' to use
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Azure OpenAI (enterprise) — set provider to 'azure_openai' to use
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-06-01
